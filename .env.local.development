# Local development environment for Nexus-Frontend
NEXT_PUBLIC_API_BASE_URL="http://127.0.0.1:8000/api"
NEXT_PUBLIC_BROADCAST_AUTH_URL="http://127.0.0.1:8000/broadcasting/auth"
NEXT_PUBLIC_REVERB_APP_KEY=local
NEXT_PUBLIC_REVERB_HOST=127.0.0.1
NEXT_PUBLIC_REVERB_PORT=6001
NEXT_PUBLIC_REVERB_SCHEME=http
NEXT_PUBLIC_REVERB_FORCE_TLS=false
NEXT_PUBLIC_ENABLE_DEBUG=true
